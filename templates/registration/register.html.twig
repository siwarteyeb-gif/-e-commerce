{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<div class="container py-5" style="background-color: skyblue; min-height: 100vh;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4 p-4 bg-white rounded shadow">
            <h2 class="mb-4 text-center">Register</h2>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}

            {{ form_row(registrationForm.email, {'label': false, 'attr': {'class': 'form-control', 'placeholder': 'Enter your email'}}) }}
            {{ form_row(registrationForm.firstName, {'label': false, 'attr': {'class': 'form-control', 'placeholder': 'Enter your first name'}}) }}
            {{ form_row(registrationForm.lastName, {'label': false, 'attr': {'class': 'form-control', 'placeholder': 'Enter your last name'}}) }}
            {{ form_row(registrationForm.plainPassword, {'label': false, 'attr': {'class': 'form-control', 'placeholder': 'Enter your password'}}) }}
            {{ form_row(registrationForm.agreeTerms, {'label': false, 'attr': {'class': 'form-check-input'}}) }}

            <button type="submit" class="btn btn-primary w-100 mt-3">Register</button>

            {{ form_end(registrationForm) }}
        </div>
    </div>
</div>
{% endblock %}